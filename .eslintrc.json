{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    // O Prettier cuida do estilo, o ESLint foca em erros de lógica
    "no-unused-vars": "warn",
    "no-console": "off"
  }
}
